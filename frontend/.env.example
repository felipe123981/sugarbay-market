# Frontend Environment Variables
# Copy this file to .env and fill in your values
#
# NOTE: Frontend runs on port 80 by default (configured in vite.config.js)
# Running on port 80 requires admin/sudo privileges on most systems

# API Base URL - used for all API requests
# For local development: leave empty (uses /api proxy to localhost:3333)
# For production/tunnel: set to your backend URL
# Example: VITE_API_BASE_URL=https://your-backend-tunnel.trycloudflare.com
VITE_API_BASE_URL=

# API Proxy Target (development only)
# Used by Vite dev server to proxy /api requests to backend
# For local development: http://localhost:3333
# For tunnel development: your cloudflared tunnel URL
# Example: VITE_API_PROXY_TARGET=https://your-backend-tunnel.trycloudflare.com
VITE_API_PROXY_TARGET=http://localhost:3333
